# Scope Content Engine
DJANGO_SECRET_KEY=CHANGE_ME_DJANGO_SECRET_KEY
CORE_JWT_SECRET=CHANGE_ME_256_BIT_RANDOM_SECRET
CORE_JWT_ISSUER=scope-core
CORE_JWT_AUDIENCE=scope-frontend
GRPC_ENABLED=false
GRPC_INTERNAL_TOKEN=CHANGE_ME_256_BIT_RANDOM_INTERNAL_GRPC_TOKEN
GRPC_ENABLE_REFLECTION=false
FRONTEND_ORIGIN=https://scope-frontend.example
DEVELOPMENT_FRONTEND_ORIGIN=http://localhost:5173
CONTENT_SERVICE_VERSION=1.0.0
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
PAGINATION_PAGE_SIZE=20
MAX_UPLOAD_BYTES=10485760
MAX_IMAGE_PIXELS=50000000
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_ENABLED=false
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_GLOBAL_PER_IP=100
RATE_LIMIT_UPLOAD_PER_USER=20
DJANGO_CACHE_BACKEND=django.core.cache.backends.locmem.LocMemCache
DJANGO_CACHE_LOCATION=scope-content-cache
CACHE_SPOTS_TIMEOUT_SECONDS=60
CACHE_FEED_TIMEOUT_SECONDS=30
LOG_LEVEL=INFO
