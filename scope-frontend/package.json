{
  "name": "scope-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --configLoader runner",
    "build": "node ./scripts/build-production.mjs",
    "wasm:build": "node ./scripts/build-scope-wasm.mjs",
    "wasm:test": "node ./scripts/verify-scope-wasm-lexer.mjs",
    "compiler:benchmark": "node ./scripts/benchmark-scope-ai-compiler.mjs",
    "scout:benchmark": "node ./scripts/benchmark-scope-ai-compiler.mjs",
    "map:benchmark": "npm run build && node ./scripts/benchmark-trips-new-map.mjs",
    "benchmark": "npm run scout:benchmark && npm run map:benchmark",
    "preview": "vite preview",
    "serve:e2e": "node ./scripts/serve-playwright-preview.mjs",
    "test": "vitest run --pool forks --maxWorkers=1 --configLoader runner",
    "test:coverage": "vitest run --pool forks --maxWorkers=1 --coverage --configLoader runner",
    "test:e2e:coverage": "node ./scripts/run-playwright-coverage.mjs",
    "test:coverage:merge": "node ./scripts/merge-test-coverage.mjs",
    "test:coverage:all": "node ./scripts/run-full-coverage.mjs",
    "test:watch": "vitest --pool forks --maxWorkers=1 --configLoader runner",
    "test:e2e": "node ./scripts/run-playwright-with-report.mjs",
    "test:e2e:raw": "playwright test",
    "qa:visual:phase13": "node ./scripts/phase13-visual-qa.mjs",
    "qa:lighthouse": "node ./scripts/phase20-lighthouse-audit.mjs",
    "lint": "eslint . --ext .vue,.ts"
  },
  "dependencies": {
    "@microsoft/signalr": "^8.0.7",
    "@sentry/vue": "^9.13.0",
    "@vueuse/core": "^12.8.2",
    "axios": "^1.8.4",
    "mapbox-gl": "^3.11.1",
    "pinia": "^2.3.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@types/istanbul-lib-coverage": "^2.0.6",
    "@types/istanbul-lib-report": "^3.0.3",
    "@types/istanbul-lib-source-maps": "^4.0.4",
    "@types/istanbul-reports": "^3.0.4",
    "@types/jsdom": "^21.1.7",
    "@types/mapbox-gl": "^3.4.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-istanbul": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^9.33.0",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-lib-source-maps": "^5.0.6",
    "istanbul-reports": "^3.2.0",
    "jsdom": "^25.0.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.16",
    "vite-plugin-istanbul": "^9.0.1",
    "vitest": "^4.1.8",
    "vue-tsc": "^2.2.8"
  },
  "overrides": {
    "js-yaml": "4.2.0"
  }
}
