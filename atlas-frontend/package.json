{
  "name": "atlas-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "serve:e2e": "npm run build && vite preview --host 127.0.0.1 --port 4173",
    "test": "vitest run --pool forks --poolOptions.forks.singleFork",
    "test:watch": "vitest --pool forks --poolOptions.forks.singleFork",
    "test:e2e": "playwright test",
    "qa:visual:phase13": "node ./scripts/phase13-visual-qa.mjs",
    "lint": "eslint . --ext .vue,.ts"
  },
  "dependencies": {
    "@microsoft/signalr": "^8.0.7",
    "@vueuse/core": "^12.8.2",
    "axios": "^1.8.4",
    "mapbox-gl": "^3.11.1",
    "pinia": "^2.3.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@types/jsdom": "^21.1.7",
    "@types/mapbox-gl": "^3.4.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.23.0",
    "eslint-plugin-vue": "^9.33.0",
    "jsdom": "^25.0.1",
    "typescript": "~5.8.3",
    "vite": "^6.2.0",
    "vitest": "^2.1.9",
    "vue-tsc": "^2.2.8"
  }
}