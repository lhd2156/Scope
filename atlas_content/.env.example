# Atlas Content Engine
DJANGO_SECRET_KEY=django-insecure-change-me-in-prod
CORE_JWT_SECRET=super-secret-256-bit-key-change-in-prod
CORE_JWT_ISSUER=atlas-core
CORE_JWT_AUDIENCE=atlas-frontend
FRONTEND_ORIGIN=https://atlas-frontend.example
DEVELOPMENT_FRONTEND_ORIGIN=http://localhost:5173
CONTENT_SERVICE_VERSION=1.0.0
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
PAGINATION_PAGE_SIZE=20
MAX_UPLOAD_BYTES=10485760
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_ENABLED=false
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_GLOBAL_PER_IP=100
RATE_LIMIT_UPLOAD_PER_USER=20
LOG_LEVEL=INFO
