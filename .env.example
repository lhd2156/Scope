# ============ GENERAL ============
NODE_ENV=development
COMPOSE_PROJECT_NAME=atlas

# ============ SQL SERVER ============
SA_PASSWORD=Atlas_Dev_2026!
ACCEPT_EULA=Y
DB_HOST=sqlserver
DB_PORT=1433
DB_NAME=atlas
DB_USER=sa
DB_PASSWORD=Atlas_Dev_2026!
SQLSERVER_MEMORY_LIMIT_MB=512

# ============ CORE PLATFORM (C#) ============
CORE_CONNECTION_STRING=Server=sqlserver,1433;Database=atlas;User Id=sa;Password=Atlas_Dev_2026!;TrustServerCertificate=True
CORE_JWT_SECRET=super-secret-256-bit-key-change-in-prod
CORE_JWT_ISSUER=atlas-core
CORE_JWT_AUDIENCE=atlas-frontend
CORE_JWT_EXPIRATION_MINUTES=15
CORE_REFRESH_TOKEN_DAYS=7

# ============ CONTENT ENGINE (Django) ============
DJANGO_SECRET_KEY=django-insecure-change-me-in-prod
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,content,nginx
DJANGO_DATABASE_URL=mssql://sa:Atlas_Dev_2026!@sqlserver:1433/atlas

# ============ INTELLIGENCE API (Flask) ============
FLASK_SECRET_KEY=flask-insecure-change-me-in-prod
FLASK_DEBUG=True
FLASK_DATABASE_URL=mssql://sa:Atlas_Dev_2026!@sqlserver:1433/atlas

# ============ KAFKA / ZOOKEEPER ============
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_HEAP_OPTS=-Xms128m -Xmx256m
KAFKA_JVM_PERFORMANCE_OPTS=-XX:+UseG1GC -XX:MaxGCPauseMillis=20 -XX:InitiatingHeapOccupancyPercent=35
ZOOKEEPER_HEAP_OPTS=-Xms64m -Xmx128m

# ============ AWS (leave blank for local dev) ============
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=atlas-photos-dev
AWS_COGNITO_USER_POOL_ID=
AWS_COGNITO_CLIENT_ID=

# ============ MAPBOX ============
VITE_MAPBOX_TOKEN=pk.your-mapbox-token-here

# ============ PORTS ============
CORE_PORT=5001
CONTENT_PORT=5002
INTEL_PORT=5003
FRONTEND_PORT=5173
NGINX_PORT=80
SQLSERVER_PORT=1433
ZOOKEEPER_PORT=2181
KAFKA_PORT=9092
